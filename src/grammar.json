{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mcbopomofo_data",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "entry"
        },
        {
          "type": "SYMBOL",
          "name": "invalid_line"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "PATTERN",
          "value": "[^\\n\\r]*"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "SYMBOL",
          "name": "_separator"
        },
        {
          "type": "SYMBOL",
          "name": "readings"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "readings": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "reading"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "hyphen"
              },
              {
                "type": "SYMBOL",
                "name": "reading"
              }
            ]
          }
        }
      ]
    },
    "invalid_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_content"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_line_content": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "word"
          },
          {
            "type": "SYMBOL",
            "name": "_separator"
          },
          {
            "type": "SYMBOL",
            "name": "hyphen"
          }
        ]
      }
    },
    "word": {
      "type": "PATTERN",
      "value": "[^\\s#\\-]+"
    },
    "reading": {
      "type": "PATTERN",
      "value": "[^\\s#\\-]+"
    },
    "hyphen": {
      "type": "STRING",
      "value": "-"
    },
    "_separator": {
      "type": "PATTERN",
      "value": "[\\t ]+"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    }
  },
  "extras": [],
  "conflicts": [
    [
      "entry",
      "_line_content"
    ],
    [
      "entry",
      "invalid_line"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}